#!/bin/bash

# prom-query - Run PromQL queries against in-cluster Prometheus
#
# Usage: prom-query QUERIES.yaml              (run all queries, save CSVs)
#        prom-query QUERIES.yaml QUERY_NAME   (run one query, save CSV)
#        prom-query QUERIES.yaml -l           (list available queries)
#        prom-query [-s START -e END -S STEP] 'PROMQL'  (inline, stdout)
#
# Examples:
#   prom-query monitoring/prom-queries.yaml
#   prom-query monitoring/prom-queries.yaml memory-per-worker
#   prom-query -s 1h -e now -S 5m 'node_memory_MemTotal_bytes'

set -eu

PROM_QUERY_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

NAMESPACE="openshift-monitoring"
POD=""
CONTAINER="prometheus"
LIST_MODE=false
RANGE_START=""
RANGE_END=""
RANGE_STEP=""
CSV_DIR=""
RAW_MODE=false
UTC_DATE_DATA_MODE=false

fatal() {
	echo "Error: $*" >&2
	exit 1
}

usage() {
	cat <<EOF
Usage: $(basename "$0") QUERIES.yaml                      Run all queries, save to csv-data/
       $(basename "$0") QUERIES.yaml QUERY_NAME           Run one query, save to csv-data/
       $(basename "$0") QUERIES.yaml -l                   List available queries
       $(basename "$0") [-s START] [-e END] [-S STEP] [-r] [-u] 'PROMQL'   Inline query to stdout

Options:
    -l             List available query names, then exit
    -s START       Range start: relative (1h, 30m, 2d) or "YYYY-MM-DD HH:MM:SS"
    -e END         Range end: "now", relative, or absolute (default: now)
    -S STEP        Range step interval (15s, 1m, 5m)
    -r             Output raw Prometheus JSON (no CSV conversion)
    -u             Output UTC CSV as date,selector,data (selector = {k="v",...} from series labels)
                  (-r and -u may also appear after QUERIES.yaml or QUERY_NAME; see examples)
    -n NAMESPACE   Prometheus namespace (default: openshift-monitoring)
    -p POD         Prometheus pod name (default: auto-detect)
    -c CONTAINER   Container name (default: prometheus)
    -h             Show help

YAML file format:
    defaults:
      start: "2026-02-19 19:00:00"
      end:   "2026-02-19 20:00:00"
      step:  15s
      threshold: 0.1   # optional; substituted for \${threshold} in query and description

    memory-per-worker:
      description: "Memory utilization per worker"
      query: |
        (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100

CSV output is saved to csv-data/ next to the YAML file, one file per query name.

Examples:
    $(basename "$0") monitoring/prom-queries.yaml
    $(basename "$0") monitoring/prom-queries.yaml memory-per-worker
    $(basename "$0") monitoring/prom-queries.yaml -l
    $(basename "$0") -s 1h -e now -S 5m 'up{job="kubelet"}'
    $(basename "$0") -r ../yaml/queries.yaml my-query
    $(basename "$0") ../yaml/queries.yaml my-query -r
EOF
	exit "${1:-0}"
}

# ---------------------------------------------------------------------------
# YAML helpers (require python3 + PyYAML)
# ---------------------------------------------------------------------------

require_python_yaml() {
	if [[ -z "$(type -t python3)" ]]; then
		fatal "python3 is required (not found in PATH)"
	fi
	python3 -c 'import yaml' 2>/dev/null \
		|| fatal "PyYAML is required (pip install pyyaml)"
}

list_queries() {
	local file="$1"
	require_python_yaml
	python3 "$PROM_QUERY_DIR/prom_query_yaml.py" list "$file"
}

# Returns all query names from the YAML (one per line, excluding "defaults")
get_query_names() {
	local file="$1"
	require_python_yaml
	python3 "$PROM_QUERY_DIR/prom_query_yaml.py" names "$file"
}

# Outputs: start, end, step (one per line), then the query (may be multi-line)
lookup_query() {
	local file="$1"
	local name="$2"
	require_python_yaml
	python3 "$PROM_QUERY_DIR/prom_query_yaml.py" lookup "$file" "$name"
}

# Resolve a time spec to a Unix timestamp.
resolve_timestamp() {
	local val="$1"
	if [[ -z "$val" ]]; then
		echo ""
		return
	fi
	case "$val" in
		now)
			date +%s ;;
		*[smhd])
			local amount="${val%[smhd]}"
			local unit="${val: -1}"
			local -A mult=([s]=1 [m]=60 [h]=3600 [d]=86400)
			echo $(( $(date +%s) - amount * ${mult[$unit]} )) ;;
		*)
			date -u -d "$val" +%s 2>/dev/null \
				|| fatal "invalid time spec \"$val\" (use \"YYYY-MM-DD HH:MM:SS\", 30s, 5m, 1h, 2d, \"now\", or unix ts)" ;;
	esac
}

# ---------------------------------------------------------------------------
# Run a single query and output CSV to stdout
#
# NOTE: We use "oc exec" (not "oc rsh") to run curl inside the Prometheus pod.
# oc rsh allocates a pseudo-terminal (PTY) whose line discipline corrupts
# large responses (injected newlines at column boundaries, doubled chars).
# oc exec streams raw bytes without a PTY, keeping the JSON intact.
# ---------------------------------------------------------------------------

run_query() {
	local query="$1"
	local range_start="$2"
	local range_end="$3"
	local range_step="$4"
	local value_header="${5:-value}"

	local is_range=false
	if [[ -n "$range_start" ]] || [[ -n "$range_step" ]]; then
		is_range=true
		if [[ -z "$range_start" ]]; then
			fatal "range query requires start"
		fi
		if [[ -z "$range_step" ]]; then
			fatal "range query requires step"
		fi
		[[ -z "$range_end" ]] && range_end="now"
	fi

	local raw_json
	if [[ "$is_range" == true ]]; then
		local ts_start ts_end
		ts_start=$(resolve_timestamp "$range_start") || exit 1
		ts_end=$(resolve_timestamp "$range_end") || exit 1
		echo "  Range [$(date -u -d @"$ts_start" '+%H:%M:%S') -> $(date -u -d @"$ts_end" '+%H:%M:%S') step $range_step]" >&2

		raw_json=$(oc exec -c "$CONTAINER" -n "$NAMESPACE" "$POD" -- \
			curl -s -w '\n%{http_code}' \
			--data-urlencode "query=$query" \
			--data-urlencode "start=$ts_start" \
			--data-urlencode "end=$ts_end" \
			--data-urlencode "step=$range_step" \
			http://localhost:9090/api/v1/query_range 2>/dev/null) || true
		local code
		code=$(echo "$raw_json" | tail -n1)
		raw_json=$(echo "$raw_json" | sed '$d')
		if [[ "$code" != "200" ]]; then
			echo "Prometheus returned HTTP $code" >&2
			echo "  Resolved PromQL (first 240 chars): ${query:0:240}" >&2
			echo "$raw_json" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('error', d.get('message', 'unknown')))" 2>/dev/null || echo "$raw_json" | head -c 500 >&2
			fatal "oc exec / curl failed — check pod name, namespace, and query syntax"
		fi
	else
		raw_json=$(oc exec -c "$CONTAINER" -n "$NAMESPACE" "$POD" -- \
			curl -s -w '\n%{http_code}' --data-urlencode "query=$query" \
			http://localhost:9090/api/v1/query 2>/dev/null) || true
		code=$(echo "$raw_json" | tail -n1)
		raw_json=$(echo "$raw_json" | sed '$d')
		if [[ "$code" != "200" ]]; then
			echo "Prometheus returned HTTP $code" >&2
			echo "  Resolved PromQL (first 240 chars): ${query:0:240}" >&2
			echo "$raw_json" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('error', d.get('message', 'unknown')))" 2>/dev/null || echo "$raw_json" | head -c 500 >&2
			fatal "oc exec / curl failed — check pod name, namespace, and query syntax"
		fi
	fi

	if [[ "$RAW_MODE" == true ]]; then
		echo "$raw_json"
		return 0
	fi

	if [[ "$UTC_DATE_DATA_MODE" == true ]]; then
		echo "$raw_json" | python3 -c '
import csv, json, sys, datetime

def ts_fmt(epoch):
    return datetime.datetime.fromtimestamp(epoch, tz=datetime.timezone.utc) \
                   .strftime("%Y-%m-%d %H:%M:%S UTC")

def metric_to_selector(metric):
    # Prometheus-style {k="v",...} from series labels (__name__ omitted).
    if not metric:
        return "{}"
    parts = []
    for k in sorted(metric.keys()):
        if k == "__name__":
            continue
        parts.append("%s=%s" % (k, json.dumps(str(metric[k]))))
    return "{" + ",".join(parts) + "}"

data = json.load(sys.stdin)
if data.get("status") != "success":
    print("Query failed:", data.get("error", "unknown error"), file=sys.stderr)
    sys.exit(1)

result_type = data.get("data", {}).get("resultType", "")
results = data.get("data", {}).get("result", [])
writer = csv.writer(sys.stdout)
writer.writerow(["date", "selector", "data"])

if not results:
    sys.exit(0)

if result_type == "matrix":
    rows = []
    for r in results:
        sel = metric_to_selector(r.get("metric", {}))
        for ts_epoch, value in r.get("values", []):
            rows.append((float(ts_epoch), sel, value))
    rows.sort(key=lambda x: (x[0], x[1]))
    for ts_epoch, sel, value in rows:
        writer.writerow([ts_fmt(ts_epoch), sel, value])
else:
    rows = []
    for r in results:
        sel = metric_to_selector(r.get("metric", {}))
        ts_epoch, value = r.get("value", [None, None])
        if ts_epoch is not None:
            rows.append((float(ts_epoch), sel, value))
    rows.sort(key=lambda x: (x[0], x[1]))
    for ts_epoch, sel, value in rows:
        writer.writerow([ts_fmt(ts_epoch), sel, value])
'
		return 0
	fi

	export QUERY_VALUE_HEADER="$value_header"
	echo "$raw_json" | python3 -c '
import json, sys, datetime, os
from collections import OrderedDict

def ts_fmt(epoch):
    return datetime.datetime.fromtimestamp(epoch, tz=datetime.timezone.utc) \
                   .strftime("%Y-%m-%d %H:%M:%S")

def get_instance(metric):
    return metric.get("instance", "unknown")

value_header = os.environ.get("QUERY_VALUE_HEADER", "value")

data = json.load(sys.stdin)
if data.get("status") != "success":
    print("Query failed:", data.get("error", "unknown error"), file=sys.stderr)
    sys.exit(1)

result_type = data.get("data", {}).get("resultType", "")
results = data.get("data", {}).get("result", [])
if not results:
    print("timestamp," + value_header)
    sys.exit(0)

if result_type == "matrix":
    instances = [get_instance(r.get("metric", {})) for r in results]
    if len(results) == 1 and not results[0].get("metric", {}):
        instances = [value_header]
    all_timestamps = OrderedDict()
    for r, inst in zip(results, instances):
        for ts_epoch, value in r["values"]:
            ts = ts_fmt(ts_epoch)
            if ts not in all_timestamps:
                all_timestamps[ts] = {}
            all_timestamps[ts][inst] = value

    print("timestamp," + ",".join(instances))
    for ts, values in all_timestamps.items():
        row = [values.get(inst, "") for inst in instances]
        print(ts + "," + ",".join(row))
else:
    instances = [get_instance(r.get("metric", {})) for r in results]
    if len(results) == 1 and not results[0].get("metric", {}):
        instances = [value_header]
    print("timestamp," + ",".join(instances))
    ts_epoch, _ = results[0]["value"]
    ts = ts_fmt(ts_epoch)
    row = [r["value"][1] for r in results]
    print(ts + "," + ",".join(row))
'
}

# ---------------------------------------------------------------------------
# Option parsing
# ---------------------------------------------------------------------------

while getopts ":n:p:c:rlus:e:S:h" opt; do
	case "$opt" in
		n) NAMESPACE="$OPTARG" ;;
		p) POD="$OPTARG" ;;
		c) CONTAINER="$OPTARG" ;;
		r) RAW_MODE=true ;;
		u) UTC_DATE_DATA_MODE=true ;;
		l) LIST_MODE=true ;;
		s) RANGE_START="$OPTARG" ;;
		e) RANGE_END="$OPTARG" ;;
		S) RANGE_STEP="$OPTARG" ;;
		h) usage 0 ;;
		:) fatal "option -$OPTARG requires an argument" ;;
		*) fatal "unknown option: -$OPTARG" ;;
	esac
done
shift $((OPTIND - 1))

if [[ "$RAW_MODE" == true ]] && [[ "$UTC_DATE_DATA_MODE" == true ]]; then
	fatal "options -r and -u are mutually exclusive"
fi

if [[ $# -lt 1 ]]; then
	fatal "missing argument (see -h for usage)"
fi

# ---------------------------------------------------------------------------
# Detect mode: YAML file vs inline PromQL
# ---------------------------------------------------------------------------

QUERY_FILE=""
if [[ -f "$1" ]] && [[ "$1" == *.yaml || "$1" == *.yml ]]; then
	QUERY_FILE="$1"
	shift
	CSV_DIR="$(dirname "$QUERY_FILE")/csv-data"
fi

# ---------------------------------------------------------------------------
# Handle -l (list mode)
# ---------------------------------------------------------------------------

if [[ "$LIST_MODE" == true ]]; then
	if [[ -z "$QUERY_FILE" ]]; then
		fatal "-l requires a YAML file"
	fi
	list_queries "$QUERY_FILE"
	exit 0
fi

# ---------------------------------------------------------------------------
# Pre-flight checks
# ---------------------------------------------------------------------------

if [[ -z "$(type -t oc)" ]]; then
	fatal "oc command is not installed"
fi

if [[ -z "$POD" ]]; then
	POD=$(oc get pods -n "$NAMESPACE" \
		-l app.kubernetes.io/name=prometheus \
		-o jsonpath='{.items[0].metadata.name}' 2>/dev/null) || true
	if [[ -z "$POD" ]]; then
		POD="prometheus-k8s-0"
		echo "Warning: could not auto-detect pod, falling back to $POD" >&2
	fi
fi

# ---------------------------------------------------------------------------
# YAML file mode: run queries and save CSVs
# ---------------------------------------------------------------------------

if [[ -n "$QUERY_FILE" ]]; then
	mkdir -p "$CSV_DIR"

	# -r/-u after YAML path or QUERY_NAME (POSIX getopts stops at first non-option, so these were ignored)
	while [[ $# -gt 0 ]]; do
		case "$1" in
			-r) RAW_MODE=true; shift ;;
			-u) UTC_DATE_DATA_MODE=true; shift ;;
			*) break ;;
		esac
	done

	query_names=()
	if [[ $# -ge 1 ]] && [[ "$1" != -* ]]; then
		query_names=("$1")
		shift
	fi

	while [[ $# -gt 0 ]]; do
		case "$1" in
			-r) RAW_MODE=true; shift ;;
			-u) UTC_DATE_DATA_MODE=true; shift ;;
			*) fatal "unexpected argument: $1" ;;
		esac
	done

	if [[ "$RAW_MODE" == true ]] && [[ "$UTC_DATE_DATA_MODE" == true ]]; then
		fatal "options -r and -u are mutually exclusive"
	fi

	if [[ ${#query_names[@]} -eq 0 ]]; then
		mapfile -t query_names < <(get_query_names "$QUERY_FILE")
	fi

	echo "Using pod $POD in $NAMESPACE" >&2
	if [[ "$RAW_MODE" == true ]]; then
		echo "Saving raw JSON to $CSV_DIR/" >&2
	elif [[ "$UTC_DATE_DATA_MODE" == true ]]; then
		echo "Saving UTC date,selector,data CSVs to $CSV_DIR/" >&2
	else
		echo "Saving CSVs to $CSV_DIR/" >&2
	fi
	echo "" >&2

	for qname in "${query_names[@]}"; do
		echo "[$qname]" >&2
		# Append sentinel so command substitution does not strip trailing newlines (breaks multi-line queries).
		local_output=$(lookup_query "$QUERY_FILE" "$qname"; printf x) || exit 1
		local_output=${local_output%x}
		{
			read -r yaml_start
			read -r yaml_end
			read -r yaml_step
			query_text=$(cat)
		} <<< "$local_output"

		# CLI flags override YAML values
		[[ -n "$RANGE_START" ]] && yaml_start="$RANGE_START"
		[[ -n "$RANGE_END" ]] && yaml_end="$RANGE_END"
		[[ -n "$RANGE_STEP" ]] && yaml_step="$RANGE_STEP"

		ext="csv"
		[[ "$RAW_MODE" == true ]] && ext="json"
		outfile="$CSV_DIR/${qname}.${ext}"
		run_query "$query_text" "$yaml_start" "$yaml_end" "$yaml_step" "$qname" > "$outfile"
		echo "  -> $outfile" >&2
		echo "" >&2
	done

	echo "Done." >&2
	exit 0
fi

# ---------------------------------------------------------------------------
# Inline PromQL mode: output to stdout
# ---------------------------------------------------------------------------

PROMQL="$1"
shift
while [[ $# -gt 0 ]]; do
	case "$1" in
		-r) RAW_MODE=true; shift ;;
		-u) UTC_DATE_DATA_MODE=true; shift ;;
		*) fatal "unexpected argument: $1" ;;
	esac
done

if [[ "$RAW_MODE" == true ]] && [[ "$UTC_DATE_DATA_MODE" == true ]]; then
	fatal "options -r and -u are mutually exclusive"
fi

run_query "$PROMQL" "$RANGE_START" "$RANGE_END" "$RANGE_STEP"
